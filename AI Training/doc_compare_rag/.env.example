# ── API Keys ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Embedding ──────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── LLM Provider ───────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic   # or openai

# ── Vector Store ───────────────────────────────────────────────────────────────
VECTOR_STORE=faiss        # or chroma

# ── Chunking ───────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
